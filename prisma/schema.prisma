generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  age       Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Department {
  id          String        @id @default(uuid())
  name        String        @unique
  createdAt  DateTime @default(now())
}